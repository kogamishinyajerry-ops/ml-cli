Actions:
  ml text tokenize  --input "hello world from matlab"
  ml text stats     --input "the quick brown fox jumps over the lazy dog."
  ml text regex     --input "phone: 555-1234" --pattern "(\d+)-(\d+)"
  ml text sentiment --input "this product is amazing"
  ml text keywords  --input "matlab rocks. matlab forever." --top 3
  ml text ngrams    --input "the quick brown fox" --n 2

Options: --input STR --file PATH --pattern REGEX --top N --n N --stopwords 1
EOF
            return 0 ;;
    esac
    forward_to "cli_text" "$@"
}

