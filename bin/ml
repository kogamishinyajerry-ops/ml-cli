# ─── 子命令: info ──────────────────────────────────────────
cmd_info() {
    local fmt="text"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)  fmt="json";  shift ;;
            --table) fmt="table"; shift ;;
            -h|--help) echo "Usage: ml info [--json|--table]"; return 0 ;;
            *) shift ;;
        esac
    done
    run_matlab "cli_info('${fmt}');"
}

# ─── 子命令: bench ──────────────────────────────────────────
cmd_bench() {
    local fmt="text"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)  fmt="json";  shift ;;
            --table) fmt="table"; shift ;;
            -h|--help) echo "Usage: ml bench [--json|--table]"; return 0 ;;
            *) shift ;;
        esac
    done
    run_matlab "cli_bench('${fmt}');"
}

# ─── 子命令: help ───────────────────────────────────────────
cmd_help() {
    if [[ $# -eq 0 ]]; then
        cat <<'EOF'
ml — MATLAB CLI Tool  v0.2

COMMANDS:
  ml eval     <expr>        Evaluate MATLAB expression
  ml run      <script.m>    Run MATLAB script
  ml skills   [phase]       List matlab-skills scripts
  ml plot     <plot_cmd>    Generate plot (--save out.png)
  ml signal   <file>        Signal analysis (--fft --psd --filter)
  ml image    <file>        Image processing (--info --gray --edge --resize)
  ml control  <tf>          Control systems (--bode --nyquist)
  ml aero     [--alt H]     Aerospace calculations (ISA, Mach)
  ml sym      <op> <expr>   Symbolic math (diff/int/solve/laplace/...)
  ml par      [--info]      Parallel computing (bench/gpu/workers)
  ml stats    <data.csv>    Statistical analysis (--json)
  ml optimize [--problem]   Optimization (--rosenbrock --himmelblau)
  ml solve    [--ode]       ODE solver (--vanderpol --lorenz --lotka)
  ml convert  <v> <from> <to>  Unit conversion
  ml mat      <action> <f.mat> .mat file ops (list/info/export/merge/compare)
  ml doc      <function>    Show MATLAB help
  ml new      <project>     Create project scaffold
  ml template <type> [name] Generate code template
  ml watch    [-n SEC] <cmd> Repeat command at interval
  ml export   <f.mat>       Export .mat to csv/json/txt
  ml test     [dir]         Run MATLAB unit tests
  ml repl                   Interactive REPL (terminal)
  ml ls      [dir] [pat]   List .m/.mat files with line counts
  ml diff    <a.m> <b.m>   Diff two MATLAB scripts
  ml profile <script.m>     Performance profile (--json)
  ml info                   MATLAB environment info
  ml bench                  Performance benchmark
  ml lint     <file.m>      Code style check
  ml lti     <action> --tf  LTI systems (poles/step/bode/margin)
  ml graph   <action> --edges  Graph analysis (shortest/mst/pagerank)
  ml fit     <action> --xy  Curve fitting (poly/exp/power/custom/interp)
  ml animate <action> --expr  Animation/GIF/MP4 generation
  ml wavelet <action> --signal  Wavelet analysis (dwt/denoise/cwt)
  ml fuzzy   <action> --name    Fuzzy inference (Mamdani/rules/eval)
  ml dnn     <action>           Deep learning inference
  ml sim     <action> --model   Simulink batch operations
  ml pde     <action> --geom    PDE solver (heat/wave/poisson)
  ml codegen <action> --file    MATLAB Coder (C/MEX generation)
  ml cv     <action> <img>      Computer Vision (features/match/track/stereo/detect)
  ml sensor <action> --meas     Sensor Fusion (ekf/ukf/imu/track/rac)
  ml sysid  <action> --y        System Identification (arx/arma/ss/tfest/compare)
  ml antenna <action> --type    Antenna Design (dipole/patch/array/pattern/sparam/mesh)
  ml robot  <action> --dh       Robotics (dh/fk/jacobian/ik/traj/rpy)
  ml vehicle <action>           Vehicle Dynamics (pacejka/steer/lanechange/straight/road)
  ml audio  <action> <file>     Audio (info/spectrogram/pitch/formant/noise/synth)
  ml lidar  <action> <cloud>    Point Cloud (info/downsample/segment/cluster/fit/view)
  ml ml     <action> <data>     Machine Learning (classify/regress/cluster/pca/cv)
  ml comms  <action> --scheme   Communications (modulate/ber/channel/eye/spectrum)
  ml time   <action> <series>   Time-Series (acf/decomp/forecast/arima/outlier)
  ml power  <action>            Power Systems (loadflow/fault/line/transformer/ed)
  ml struct <action>            Structural (beam/column/torsion/modal/truss)
  ml help     [cmd]         Show help

OPTIONS (on supported commands):
  --json     JSON output (pipe to jq)
  --table    Markdown table
  --csv      CSV output
  --save F   Save output to file

PIPELINE:
  echo "1:10" | ml eval "sum(ans)"
  ml bench --json | jq '.matrix_multiply_1k'
  ml data file.csv --stats --json | jq '.[0].mean'

EOF
    else
        local cmd="$1"
        case "$cmd" in
            eval|run|plot|signal|image|control|aero|info|bench|lint|help)
                "$0" "$cmd" --help 2>/dev/null || echo "ml $cmd — no help available"
                ;;
            *) echo "Unknown command: $cmd";;
        esac
    fi
}

# ─── 主入口 ──────────────────────────────────────────────────
main() {
    [[ $# -eq 0 ]] && { cmd_help; exit 0; }

    case "$1" in
        -h|--help)    cmd_help; exit 0 ;;
        -v|--version) version;  exit 0 ;;
    esac

    local cmd="$1"; shift
    case "$cmd" in
        help)    cmd_help "$@"    ;;
        eval)    cmd_eval "$@"    ;;
        run)     cmd_run "$@"     ;;
        skills)  cmd_skills "$@"  ;;
        plot)    cmd_plot "$@"    ;;
        signal)  cmd_signal "$@"  ;;
        image)   cmd_image "$@"   ;;
        control) cmd_control "$@" ;;
        aero)    cmd_aero "$@"    ;;
        sym)     cmd_sym "$@"     ;;
        par)     cmd_par "$@"     ;;
        stats)   cmd_stats "$@"   ;;
        optimize) cmd_optimize "$@" ;;
        solve)   cmd_solve "$@"   ;;
        convert) cmd_convert "$@" ;;
        doc)     cmd_doc "$@"     ;;
        new)     cmd_new "$@"     ;;
        template) cmd_template "$@" ;;
        watch)  cmd_watch "$@"  ;;
        export) cmd_export "$@" ;;
        test)   cmd_test "$@"   ;;
        repl)   cmd_repl "$@"   ;;
        ls)     cmd_ls "$@"     ;;
        diff)   cmd_diff "$@"   ;;
        profile) cmd_profile "$@" ;;
        mat)     cmd_mat "$@"     ;;
        info)    cmd_info "$@"    ;;
        bench)   cmd_bench "$@"   ;;
        lint)    cmd_lint "$@"    ;;
        fmt)     cmd_fmt "$@"     ;;
        lti)     cmd_lti "$@"     ;;
        graph)   cmd_graph "$@"   ;;
        fit)     cmd_fit "$@"     ;;
        animate) cmd_animate "$@" ;;
        wavelet) cmd_wavelet "$@" ;;
        fuzzy)   cmd_fuzzy "$@"   ;;
        dnn)     cmd_dnn "$@"     ;;
        sim)     cmd_sim "$@"     ;;
        pde)     cmd_pde "$@"     ;;
        codegen) cmd_codegen "$@" ;;
        cv)      cmd_cv "$@"      ;;
        sensor)  cmd_sensor "$@"  ;;
        sysid)   cmd_sysid "$@"   ;;
        antenna) cmd_antenna "$@" ;;
        robot)   cmd_robot "$@"   ;;
        vehicle) cmd_vehicle "$@" ;;
        audio)   cmd_audio "$@"   ;;
        lidar)   cmd_lidar "$@"   ;;
        ml)      cmd_ml "$@"      ;;
        comms)   cmd_comms "$@"   ;;
        time)    cmd_time "$@"    ;;
        power)   cmd_power "$@"   ;;
        struct)  cmd_struct "$@"  ;;
        text)    cmd_text "$@"    ;;
        finance) cmd_finance "$@" ;;
        map)     cmd_map "$@"     ;;
        crypto)  cmd_crypto "$@"  ;;
        bio)     cmd_bio "$@"     ;;
        chem)    cmd_chem "$@"    ;;
        physics) cmd_physics "$@" ;;
        astro)   cmd_astro "$@"   ;;
        queue)   cmd_queue "$@"   ;;
        game)    cmd_game "$@"    ;;
        color)   cmd_color "$@"   ;;
        *)       die "unknown '${cmd}'. Try: ml help" ;;
    esac
}

main "$@"
