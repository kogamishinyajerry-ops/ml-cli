# ─── 子命令: ml ml ──────────────────────────────────────────
cmd_ml() {
    case "$1" in
        -h|--help)
            cat <<'EOF'
ml ml — Machine Learning (classify/regress/cluster/pca/cv/predict)

Actions:
  ml ml classify  <data.csv> --target label --method tree      train + evaluate
  ml ml regress   <data.csv> --target y --method svm           regression
  ml ml cluster   <data.csv> --k 3                             kmeans clustering
  ml ml pca       <data.csv> --components 2                    PCA
  ml ml split     <data.csv> --ratio 0.8                       train/test split
  ml ml train     <data.csv> --target label --method forest --save model.mat
  ml ml predict   model.mat <new.csv> [--out preds.csv]
  ml ml cv        <data.csv> --target label --method knn --folds 5
  ml ml features  <data.csv> --target label
  ml ml dnn       <data.csv> --target label --layers "10,8" --epochs 50
  ml ml dnpredict model.mat <new.csv>
  ml ml dninfo    model.mat
  ml ml features  <data.csv> --target label                    importance ranking

Methods: tree|forest|svm|knn|nb|linear|logistic (classify)
         tree|forest|svm|linear|gp (regress)
         dnn: --layers "10,8" --epochs N --lr VAL --task class|reg
Options: --k N --components N --ratio R --folds N --save PATH --out PATH
         --format json|table|csv
EOF
            return 0 ;;
    esac
    forward_to "cli_ml" "$@"
}

