Actions:
  ml game nash     --payoff "[3,0,5,1,0,2,4,3]"
  ml game dominant --payoff "[3,0,5,1,0,2,4,3]"
  ml game prisoner --tempt 5 --reward 3 --punish 1 --sucker 0
