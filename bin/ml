  ml lti poles   --tf "[1] / [1 0.5 1]"
  ml lti step    --tf "..." --tfinal 30
  ml lti bode    --tf "..." --wmin 0.01 --wmax 10 --npts 100
  ml lti nyquist --tf "..." --wmin 0.1 --wmax 10
  ml lti margin  --tf "..."
  ml lti roots   --tf "..."

System spec:
  --tf "num / den"              transfer function
  --zpk "z:[z1,z2] p:[p1,p2] k:k"  zeros/poles/gain

Options:
  --tfinal T    --n N   --wmin/--wmax/--npts  --w w1,w2,...
  --plot F.png   --format json|table|csv
HELP
            return 0 ;;
    esac
    [[ $# -lt 2 ]] && die "lti needs action and system spec. ml lti info --tf \"[1]/[1 0.5 1]\""
    forward_to "cli_lti" "$@"
}

